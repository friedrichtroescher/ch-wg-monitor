OPENROUTER_API_KEY=sk-or-v1-...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Captcha solving (only needed for portals gated by reCAPTCHA, e.g. wgzimmer).
# Without a key, captcha-gated searches are skipped. Provider defaults to 2captcha.
# CAPTCHA_API_KEY=...
# CAPTCHA_PROVIDER=2captcha

# Controls whether log lines on stdout include timestamps.
# unset = auto-detect (on in terminals, off in pipes/cron).
# true = always include
# false = always omit
# LOG_TIMESTAMP=true

# OpenTelemetry (optional – omit OTEL_EXPORTER_OTLP_ENDPOINT to disable)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
# OTEL_SERVICE_NAME=kleinanzeigen-monitor
# DEPLOYMENT_ENVIRONMENT=production
