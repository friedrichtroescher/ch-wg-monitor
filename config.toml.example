[schedule]
# Hours (0-23) at which the script should run
times = [8, 12, 18]

[model]
# OpenRouter model.
# Note that reasoning models are not supported due to model-specific https response formats keys
# Suggested models:
#   "google/gemini-2.0-flash-lite-001"   (very cheap, fast)
#   "anthropic/claude-haiku-4-5"         (good + cheap)
#   "meta-llama/llama-3.1-8b-instruct"  (free on OpenRouter)
id = "google/gemini-2.0-flash-lite-001"

[network]
# Number of retries on connection errors (0 = no retry)
retries = 2

[logging]
level = "INFO"   # DEBUG | INFO | WARNING | ERROR | CRITICAL

[assistant]
# Shared context for all searches (optional)
common_prompt = "I'm looking for used items in good condition at fair prices."

# Optional global defaults for all searches.
# Each can be overridden per [[searches]] block, or omitted entirely (built-in defaults apply).
# Built-in defaults: deep_eval = false, max_price = unset (model is told there is no price limit)
#
# deep_eval: if false, evaluates listings from the search overview page only.
#            if true, fetches the detail page for a more precise second evaluation step.
#            true causes more https requests and openrouter token usage.
# deep_eval = false
# max_price = 0

# Searches – add as many [[searches]] blocks as needed.
#
# portal: which site to scrape. Optional — inferred from the URL host if omitted.
#         Supported: "flatfox" (flatfox.ch, JSON API), "kleinanzeigen" (legacy).
#         "wgzimmer" (wgzimmer.ch) is planned.
# url:    build the search on the portal's website (set your region/filters), then paste the URL.
#         For flatfox, paste the frontend search URL (…/de/suche/?…) — its query params
#         (map area, filters) are forwarded to the Flatfox API automatically.
# Optional: max_price (CHF), deep_eval (override global above), addition_prompt.
[[searches]]
portal = "flatfox"
url = "https://flatfox.ch/de/suche/?object_category=SHARED&north=47.43&south=47.32&east=8.62&west=8.45"
max_price = 1200
addition_prompt = "WG-Zimmer in Zürich, unbefristet, Einzug ab sofort, ruhige Lage bevorzugt."

[[searches]]
portal = "flatfox"
url = "https://flatfox.ch/de/suche/?object_category=SHARED"
# no location filter → all Swiss WG rooms; max_price/deep_eval inherit from [assistant] or defaults
addition_prompt = "Möbliertes Zimmer, WG mit max. 4 Personen."

# wgzimmer: adapter exists but is currently NON-FUNCTIONAL — its search is gated by
# reCAPTCHA v3, which returns no results for datacenter-solved tokens (would need a headless
# browser). Left here for reference; enable only once a Playwright fetch path exists.
# Requires CAPTCHA_API_KEY (2captcha) + deep_eval = true. Canton slug e.g. "rapperswil-jona".
# [[searches]]
# portal = "wgzimmer"
# state = "rapperswil-jona"
# permanent = true
# max_price = 1200
# deep_eval = true
# addition_prompt = "WG-Zimmer im Umfeld von Rapperswil."
